{
  "$ref": "#/definitions/agent-frontmatter",
  "definitions": {
    "agent-frontmatter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "const": "agent"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "version": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disallowedTools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claude": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "enum": [
                "haiku",
                "sonnet",
                "opus"
              ]
            },
            "effort": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            },
            "maxTurns": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "isolation": {
              "type": "string",
              "enum": [
                "worktree"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "kind",
        "title",
        "description",
        "name"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
