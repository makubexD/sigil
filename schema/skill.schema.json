{
  "$ref": "#/definitions/skill-frontmatter",
  "definitions": {
    "skill-frontmatter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "const": "skill"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "version": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "appliesTo": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*"
          ]
        },
        "uses": {
          "type": "object",
          "properties": {
            "rules": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "agents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {}
        }
      },
      "required": [
        "id",
        "kind",
        "title",
        "description",
        "name",
        "language"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
